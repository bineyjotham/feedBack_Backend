{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Hangfire": "Information"
    }
  },
    "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=${SQL_SERVER_HOST};Database=FeedbackDB;User ID=${SQL_SERVER_USER};Password=${SQL_SERVER_PASSWORD};MultipleActiveResultSets=true;TrustServerCertificate=true",
    "HangfireConnection": "Server=${SQL_SERVER_HOST};Database=FeedbackDB_Hangfire;User ID=${SQL_SERVER_USER};Password=${SQL_SERVER_PASSWORD};MultipleActiveResultSets=true;TrustServerCertificate=true",
    "Redis": "${REDIS_CONNECTION}"
  },
  "SendGrid": {
    "ApiKey": "${SENDGRID_API_KEY}",
    "FromEmail": "data.alert@xdsdatagh.com",
    "FromName": "XDS Data Ghana",
    "TeamEmail": "dispute@xdsdata.com"
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowInSeconds": 60,
    "QueueLimit": 2
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "ExpiryInMinutes": 10
  },
  "DefaultAdminPassword": "${DEFAULT_ADMIN_PASSWORD}",
  "EmailRetry": {
    "MaxAttempts": 3,
    "InitialDelaySeconds": 60,
    "MaxDelaySeconds": 360
  }
}