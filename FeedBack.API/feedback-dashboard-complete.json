{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "API Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(api_requests_total[$__rate_interval]))", "legendFormat": "Total Requests" },
        { "expr": "sum(rate(api_requests_total{status_code=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx Errors" },
        { "expr": "sum(rate(api_requests_total{status_code=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx Errors" }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_milliseconds_bucket[$__rate_interval])) by (le, endpoint))", "legendFormat": "P99 - {{endpoint}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_milliseconds_bucket[$__rate_interval])) by (le, endpoint))", "legendFormat": "P95 - {{endpoint}}" },
        { "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_milliseconds_bucket[$__rate_interval])) by (le, endpoint))", "legendFormat": "P50 - {{endpoint}}" }
      ],
      "title": "API Response Time (Percentiles)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "panels": [],
      "title": "Database Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": { "legend": { "calcs": [], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(database_query_duration_milliseconds_bucket[$__rate_interval])) by (le, operation))", "legendFormat": "{{operation}} - P95" }
      ],
      "title": "Database Query Performance by Operation",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "database_connection_pool_size", "legendFormat": "Connection Pool Size" }
      ],
      "title": "Database Connection Pool",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "panels": [],
      "title": "Business Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "options": { "legend": { "calcs": [], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(increase(feedback_submitted_total[$__rate_interval])) by (source)", "legendFormat": "{{source}}" }
      ],
      "title": "Feedback Submissions by Source",
      "type": "barchart"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showUnfilled": true },
      "targets": [
        { "expr": "sum(feedback_rating_summary_sum) by (source) / sum(feedback_rating_summary_count) by (source)", "legendFormat": "{{source}}" }
      ],
      "title": "Average Rating by Source",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "panels": [],
      "title": "Infrastructure Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 11,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"feedback-api\"}", "legendFormat": "CPU Usage" }
      ],
      "title": "Container CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 12,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=\"feedback-api\"}", "legendFormat": "Memory Usage" }
      ],
      "title": "Container Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 13,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=\"feedback-api\"}[$__rate_interval])", "legendFormat": "Network In" },
        { "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=\"feedback-api\"}[$__rate_interval])", "legendFormat": "Network Out" }
      ],
      "title": "Network I/O",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["feedback", "api", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Feedback API - Complete Monitoring",
  "uid": "feedback-api-monitoring",
  "version": 1
}